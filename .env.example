# .env.example — このファイルをコピーして .env を作成してください
# cp .env.example .env

PORT=8000

# PostgreSQL接続設定（自分で値を決めてください）
POSTGRES_USER=your_db_user
POSTGRES_PASSWORD=your_db_password
POSTGRES_DB=your_db_name

# FastAPI用の接続URL（上の値を当てはめてください）
DATABASE_URL=postgresql+asyncpg://your_db_user:your_db_password@db:5432/your_db_name

# SQLログ（開発時のみ true にする。本番は false のまま）
SQL_ECHO=false
